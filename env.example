# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For MySQL: django.db.backends.mysql
# For SQLite: django.db.backends.sqlite3
DB_ENGINE=django.db.backends.mysql
DB_NAME=Aidrawsql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password-here

# Static and Media Files
STATIC_ROOT=/path/to/staticfiles
MEDIA_ROOT=/path/to/media

# GroundingDINO Paths (adjust according to your setup)
GROUNDINGDINO_PATH=/home/GroundingDINO
CONDA_ENV_NAME=torchdraw

# Data Paths
IMAGE_BASE_PATH=/data/Imagebase
LORA_MODELS_PATH=/data/lorafile
MODEL_DIR_PATH=/data/modelfile
BOXES_JSON_PATH=/data/boxesjson
DETECT_OUTPUT_PATH=/data/detect_output

